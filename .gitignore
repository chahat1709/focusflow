# ── FocusFlow .gitignore ──

# Environment secrets (NEVER commit)
.env
.env.local
.env.template
.muse_address

# Local database (user-specific)
focusflow_local.db
focusflow_local.db-wal
focusflow_local.db-shm

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Build artifacts
dist/
build/
*.spec
node_modules/

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Logs & debug output
*.log
*.txt

# Scratch files (not part of the project)
analyze_predator.py
find_proj.py
tmp/

