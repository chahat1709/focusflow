{
    "name": "omni-monitor",
    "version": "1.0.0",
    "description": "Advanced Muse 2 Biofeedback Dashboard with IAF Tuning",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "keywords": [
        "muse",
        "eeg",
        "biofeedback",
        "neuroscience"
    ],
    "author": "Your Name",
    "license": "PROPRIETARY",
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.0",
        "javascript-obfuscator": "^4.1.0",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "electron-updater": "^6.1.7"
    },
    "build": {
        "appId": "com.omnimonitor.app",
        "productName": "Omni-Monitor",
        "directories": {
            "output": "release"
        },
        "files": [
            "main.js",
            "preload.js",
            "dashboard.html",
            "build/**/*",
            "!**/*.py",
            "!**/*.pyc"
        ],
        "asar": {
            "smartUnpack": false
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "publish": {
            "provider": "github",
            "owner": "your-username",
            "repo": "omni-monitor"
        }
    }
}